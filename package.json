    "fix-encoding": "node scripts/fix-encoding.mjs",
    "download-images": "node scripts/download-images.mjs",
    "download-categories": "node scripts/download-category-images.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.8.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.10.5",
    "lucide-react": "^0.510.0",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.2.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "prisma": "6.8.2",
