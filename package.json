{
  "name": "petstore-kuwait",
  "version": "1.0.0",
  "private": true,
  "description": "Pet Store Kuwait — Your Dependable Partner in PetHood",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:reset": "prisma db push --force-reset && node prisma/seed.mjs",
    "scrape": "node scripts/scrape-products.mjs",
    "scrape:no-images": "node scripts/scrape-products.mjs --no-images",
